{
  "name": "votiy-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env.local src/server.js",
    "dev": "node --env-file-if-exists=.env.local src/server.js",
    "dev:watch": "node --env-file-if-exists=.env.local --watch-path=src src/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cookie": "^2.0.1",
    "graphql": "^16.11.0",
    "mongodb": "^7.0.0",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
