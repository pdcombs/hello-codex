NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://votiy_app:localpassword@127.0.0.1:27017/votiy?authSource=votiy
MONGODB_DATABASE=votiy
APP_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=votiy_session
SESSION_TTL_SECONDS=1209600
SESSION_IDLE_TTL_SECONDS=604800
TOKEN_PEPPER=replace-with-a-long-local-only-random-value
VERIFICATION_TTL_SECONDS=86400
EMAIL_TRANSPORT=mailpit
EMAIL_FROM=Votiy <no-reply@votiy.local>
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
EMAIL_PROVIDER_ENDPOINT=
EMAIL_PROVIDER_API_KEY=
LOG_LEVEL=info
